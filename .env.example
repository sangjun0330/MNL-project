NEXT_ALLOWED_DEV_ORIGINS=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://rnest.kr
# 로컬 개발에서는 브라우저 현재 origin(http://localhost:3000 등)이 OAuth callback에 우선 사용됩니다.

# ============================================================
# ⚠️  보안 주의사항
# ============================================================
# 1. 이 파일을 복사해 .env 또는 .env.local 로 사용하세요.
# 2. .env / .env.local 은 절대 git에 커밋하지 마세요.
# 3. NEXT_PUBLIC_ 접두사는 빌드 후 브라우저에 완전 공개됩니다.
#    API 키/시크릿 키에는 절대 NEXT_PUBLIC_ 을 붙이지 마세요.
#    (예: NEXT_PUBLIC_OPENAI_API_KEY 설정 금지)
# 4. .wnl_users/, .wnl_logs/ 폴더는 실제 사용자 건강정보(PII)를
#    포함하므로 git에 추가하지 마세요. (.gitignore에 등록됨)
# ============================================================

# OpenAI (서버 전용 — NEXT_PUBLIC_ 접두사 사용 금지)
OPENAI_API_KEY=sk-your-openai-key-here
#
# 선택: Cloudflare AI Gateway를 통한 OpenAI 우회/프록시
# Responses API 기준 권장값은 /openai 입니다.
# /compat, /openai/chat/completions 형태를 넣어도 서버에서 /openai/responses로 자동 정규화합니다.
# OPENAI_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/openai
# OPENAI_RECOVERY_BASE_URL=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/openai
# OPENAI_RECOVERY_MAX_OUTPUT_TOKENS=2200
# OPENAI_RECOVERY_BRIEF_MAX_OUTPUT_TOKENS=2200
# OPENAI_RECOVERY_ORDERS_MAX_OUTPUT_TOKENS=1400
# OPENAI_MED_SAFETY_BASE_URLS=https://gateway.ai.cloudflare.com/v1/<account>/<gateway>/openai
# Gateway auth 토큰(Cloudflare 대시보드 예시의 CF_AIG_TOKEN)
# CF_AIG_TOKEN=
# 선택: auto | request_header | stored_key
# - auto: CF_AIG_TOKEN 없으면 OPENAI_API_KEY 직접 사용, 둘 다 있으면 request_header, OPENAI_API_KEY 없으면 stored_key
# - request_header: Authorization=OPENAI_API_KEY + cf-aig-authorization=CF_AIG_TOKEN (권장)
# - stored_key: cf-aig-authorization=CF_AIG_TOKEN + OPENAI_API_KEY fallback Authorization 포함
#   ※ Cloudflare BYOK(대시보드 저장 키) 없이도 OPENAI_API_KEY가 있으면 정상 동작함
# OPENAI_GATEWAY_AUTH_MODE=auto
# 선택: true면 stored_key 모드 강제
# OPENAI_GATEWAY_USE_STORED_KEY=false

# AI Med Safety
# 권장 범위: 9000~20000 (잘림 방지용 넉넉한 출력)
OPENAI_MODEL=gpt-5.4
OPENAI_MAX_OUTPUT_TOKENS=9600
OPENAI_MED_SAFETY_MODEL=gpt-5.4
OPENAI_MED_SAFETY_MAX_OUTPUT_TOKENS=14000
# AI 검색기 모델 고정(gpt-5.4 단일 사용)
OPENAI_MED_SAFETY_FALLBACK_MODELS=gpt-5.4
# 네트워크 재시도(권장 1~3)
OPENAI_MED_SAFETY_NETWORK_RETRIES=2
OPENAI_MED_SAFETY_NETWORK_RETRY_BASE_MS=700
# 선택: 기본/대체 API 베이스 URL 목록(쉼표 구분)
# OPENAI_MED_SAFETY_BASE_URLS=https://api.openai.com/v1
# OpenAI dashboard Logs/Responses 저장. 로그 확인이 필요하면 true 유지 권장
OPENAI_MED_SAFETY_STORE=true
# OpenAI 상위 호출 단건 타임아웃(ms)
OPENAI_MED_SAFETY_UPSTREAM_TIMEOUT_MS=120000
# 전체 분석 최대 대기시간(ms): 초과 시 fallback
OPENAI_MED_SAFETY_TOTAL_BUDGET_MS=420000
# 분석 요청 타임아웃(ms)
OPENAI_MED_SAFETY_TIMEOUT_MS=600000
# med-safety 최근 검색 서버 저장 보존기간(일) — 민감정보 최소화를 위해 짧게 유지 권장
MED_SAFETY_HISTORY_RETENTION_DAYS=30

# Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DATABASE_URL=postgresql://user:pass@host:5432/postgres
# 선택: 테스트 중 허용할 계정만 앱 레벨에서 제한 (쉼표/줄바꿈 구분)
AUTH_ALLOWED_EMAILS=
# 선택: true이면 기존 앱 사용자(rnest_users)에 없는 새 OAuth 유저는 차단합니다.
AUTH_REQUIRE_EXISTING_USER=false

# TossPayments
NEXT_PUBLIC_TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key
TOSS_API_ACCEPT_LANGUAGE=ko-KR
# Optional (test key only): forces test error simulation code from Toss docs
TOSS_TEST_CODE=
# ⚠️ 필수(운영): 미설정 시 모든 결제 웹훅이 차단됩니다. 32자 이상 랜덤 문자열 권장
TOSS_WEBHOOK_TOKEN=
# ⚠️ 권장(운영): 토스 웹훅 IP 대역만 허용. 미설정 시 모든 IP 허용(보안 취약)
# 토스페이먼츠 공식 IP 목록: https://docs.tosspayments.com/reference/webhook
TOSS_WEBHOOK_IP_ALLOWLIST=
# ⚠️ 임시 호환 옵션(비권장): 헤더(x-toss-webhook-token) 대신 query token 허용
# 운영에서는 비워두거나 0으로 두세요.
TOSS_WEBHOOK_ALLOW_QUERY_TOKEN=0
# ⚠️ 긴급 복구용 임시 옵션(비권장): IP allowlist 미설정 상태에서도 웹훅 허용
# 운영에서는 비워두거나 0으로 두세요.
TOSS_WEBHOOK_ALLOW_INSECURE_NO_IP_ALLOWLIST=0

# 관리자 설정
# ⚠️ 필수: 환불 처리 알림을 받을 관리자 이메일 (소스코드에 직접 입력 금지)
REFUND_ADMIN_EMAIL=your-admin@example.com
# 관리자 User ID 목록 (쉼표 구분, Supabase auth.users.id 기준)
BILLING_ADMIN_USER_IDS=
# 관리자 이메일 목록 (쉼표 구분, 대소문자 무시)
BILLING_ADMIN_EMAILS=

# 계정삭제 보안
# 계정 삭제 전 최근 로그인(초) 요구. 기본 900초(15분)
ACCOUNT_DELETE_REAUTH_MAX_AGE_SEC=900
